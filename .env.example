# FashionSense AI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                        # development | staging | production
APP_SECRET_KEY=change-me-to-a-random-32-char-string
DEBUG=true

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/fashionsense
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis (inference cache) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── AWS S3 (image + heatmap storage) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=fashionsense-uploads
S3_PRESIGNED_URL_EXPIRY=300                # seconds (5 min, per SRS spec)

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-different-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── ML Inference Server ───────────────────────────────────────────────────────
MODEL_CHECKPOINT_PATH=checkpoints/best_classifier.pt
COMPAT_CHECKPOINT_PATH=checkpoints/best_compatibility.pt
MODEL_CONFIG_PATH=checkpoints/model_config.json
INFERENCE_DEVICE=cuda                      # cuda | cpu
MAX_IMAGE_SIZE_MB=2
MAX_IMAGE_PX=1200

# ── Anthropic / LLM (outfit suggestion narrative) ────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=512

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
